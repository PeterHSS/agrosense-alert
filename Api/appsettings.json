{
    "ConnectionStrings": {
        "Default": "Host=localhost;Port=5334;Database=agrosense_alerts;Username=agrosense;Password=agrosense;"
    },
    "RabbitMQ": {
        "Host": "localhost",
        "Port": 5672,
        "Username": "agrosense",
        "Password": "agrosense"
    },
    "Jwt": {
        "Secret": "super-duper-secret-value-that-should-be-in-user-secrets",
        "Issuer": "agrosense-identity",
        "Audience": "developers",
        "ExpirationInMinutes": 15
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.EntityFrameworkCore": "Warning",
                "System": "Warning"
            }
        },
        "Enrich": [
            "FromLogContext",
            "WithMachineName",
            "WithThreadId"
        ],
        "Properties": {
            "Service": "AgroSense.Alert",
            "Environment": "Production"
        },
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
                }
            },
            {
                "Name": "GrafanaLoki",
                "Args": {
                    "uri": "http://host.docker.internal:3100/",
                    "propertiesAsLabels": [ "Service", "Environment" ],
                    "labels": [
                        {
                            "key": "app",
                            "value": "agrosense-alert"
                        },
                        {
                            "key": "env",
                            "value": "production"
                        }
                    ]
                }
            }
        ]
    }
}
